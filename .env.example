# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI providers
# Recommended first provider for P0: OpenAI.
# Keep the app provider-shaped so it can be swapped later.
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL_MULTIMODAL=gpt-5.4-mini
AI_MODEL_TEXT=gpt-5.4-mini

# ASR
ASR_PROVIDER=openai
ASR_API_KEY=
ASR_MODEL=gpt-4o-mini-transcribe

# TTS
# P0 can run without this by falling back to browser SpeechSynthesis.
TTS_PROVIDER=browser
TTS_API_KEY=
TTS_VOICE=

# Music generation
MUSIC_PROVIDER=replicate
REPLICATE_API_TOKEN=
MUSICGEN_MODEL=

# Qiniu Cloud
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_REGION=
QINIU_PUBLIC_DOMAIN=

# Optional Spotify integration, P2 only
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=
